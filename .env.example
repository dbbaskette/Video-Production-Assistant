# ─── VPA Application ───────────────────────────────────────────────
# Where VPA stores app config (tracker, brands, voices)
VPA_HOME=~/.vpa

# Default folder root for new projects
VPA_PROJECTS_DEFAULT=~/Movies/VPA

# ─── Server ────────────────────────────────────────────────────────
VPA_SERVER_PORT=3000
VPA_SERVER_HOST=127.0.0.1

# ─── Web (Vite reads VITE_* prefix) ───────────────────────────────
VITE_VPA_API_BASE=http://localhost:3000

# ─── LLM Provider ─────────────────────────────────────────────────
# Options: fake | claude-code | gemini | anthropic
#
#   fake         — deterministic dev responses, no external calls (default)
#   claude-code  — uses `claude -p` subprocess, requires Claude Code CLI installed
#                  and logged in. No API key needed — uses your Claude subscription.
#   gemini       — Google Gemini REST API, requires GEMINI_API_KEY
#   anthropic    — Anthropic REST API, requires ANTHROPIC_API_KEY
#
VPA_LLM_PROVIDER=fake

# Claude Code CLI — no API key needed, just install Claude Code and log in:
#   https://claude.ai/code
# When VPA_LLM_PROVIDER=claude-code you can optionally set the model:
# VPA_LLM_MODEL=sonnet

# Gemini (Google AI) — required when VPA_LLM_PROVIDER=gemini
# Get a key at https://aistudio.google.com/apikey
# GEMINI_API_KEY=

# Anthropic REST API — required when VPA_LLM_PROVIDER=anthropic
# Only needed if you prefer direct API access over claude-code.
# Get a key at https://console.anthropic.com/settings/keys
# ANTHROPIC_API_KEY=
